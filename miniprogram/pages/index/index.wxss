.lobby {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f0f2f5;
  gap: 32rpx;
  padding: 40rpx 80rpx;
  box-sizing: border-box;
}

.title {
  font-size: 64rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 12rpx;
}

.cols {
  display: flex;
  gap: 32rpx;
  width: 100%;
  max-width: 540rpx;
}

.col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.btn {
  width: 100%;
  height: 60rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn.go {
  background: #07c160;
  color: #fff;
}

.btn.swap {
  background: #f0ad4e;
  color: #fff;
}

.btn.off {
  background: #f5f5f5;
  color: #bbb;
}
